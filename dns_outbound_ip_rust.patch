+//! the connection through the interface that owns the address, regardless of
+//! the global routing table and regardless of which proxy mode is active
+//! (apps_script, direct, full).
+//!
+//! DNS resolution goes through `resolve_host` which uses a `hickory-resolver`
+//! instance bound to `dns_outbound_ip` (falls back to `outbound_ip`, then OS
+//! default).  This lets DNS and data traffic use completely separate interfaces.
 
 use std::net::{IpAddr, SocketAddr};
 use tokio::net::{TcpSocket, TcpStream};
+use std::sync::OnceLock;
+use hickory_resolver::TokioAsyncResolver;
+use hickory_resolver::config::{ResolverConfig, ResolverOpts, NameServerConfig, Protocol};
+
+// ── Global DNS resolver ──────────────────────────────────────────────────────
+// Built once at startup from `dns_outbound_ip` (or `outbound_ip` as fallback).
+// `OnceLock` is safe across async tasks; the resolver itself is cheaply cloneable.
+static DNS_RESOLVER: OnceLock<TokioAsyncResolver> = OnceLock::new();
+
+/// Initialise the global DNS resolver.
+///
+/// * `dns_bind_ip`  – IP to bind the UDP/TCP DNS socket to (`dns_outbound_ip`).
+/// * `fallback_ip`  – used when `dns_bind_ip` is `None` (`outbound_ip`).
+///
+/// When both are `None` the OS default resolver is used (zero configuration).
+/// Call this once, early in `main` / server startup, before the first query.
+pub fn init_dns_resolver(
+    dns_bind_ip: Option<&str>,
+    fallback_ip: Option<&str>,
+) {
+    let bind_ip = dns_bind_ip.or(fallback_ip);
+
+    let resolver = match bind_ip {
+        None => {
+            // No binding requested — use OS default resolver config.
+            TokioAsyncResolver::tokio(
+                ResolverConfig::default(),
+                ResolverOpts::default(),
+            )
+        }
+        Some(ip_str) => {
+            let bind_addr: IpAddr = match ip_str.parse() {
+                Ok(a) => a,
+                Err(e) => {
+                    tracing::warn!(
+                        "dns_outbound_ip '{}' is invalid ({}); falling back to OS resolver",
+                        ip_str, e
+                    );
+                    let r = TokioAsyncResolver::tokio(
+                        ResolverConfig::default(),
+                        ResolverOpts::default(),
+                    );
+                    let _ = DNS_RESOLVER.set(r);
+                    return;
+                }
+            };
+
+            // Use well-known public DNS servers but bind the socket to the
+            // chosen interface so the OS routes the UDP/TCP packet from there.
+            let name_servers = vec![
+                ("8.8.8.8",   53u16),
+                ("8.8.4.4",   53u16),
+                ("1.1.1.1",   53u16),
+                ("1.0.0.1",   53u16),
+            ];
+
+            let mut rc = ResolverConfig::new();
+            for (ip, port) in name_servers {
+                let ns_addr: IpAddr = ip.parse().unwrap();
+                // Only add servers that match the address family of the bind IP.
+                match (bind_addr, ns_addr) {
+                    (IpAddr::V4(_), IpAddr::V4(_)) | (IpAddr::V6(_), IpAddr::V6(_)) => {
+                        rc.add_name_server(NameServerConfig {
+                            socket_addr: SocketAddr::new(ns_addr, port),
+                            protocol: Protocol::Udp,
+                            tls_dns_name: None,
+                            trust_negative_responses: false,
+                            bind_addr: Some(SocketAddr::new(bind_addr, 0)),
+                            tls_config: None,
+                        });
+                    }
+                    _ => {} // skip mismatched address families
+                }
+            }
+
+            let mut opts = ResolverOpts::default();
+            opts.cache_size = 256;
+            opts.timeout    = std::time::Duration::from_secs(5);
+            opts.attempts   = 2;
+
+            TokioAsyncResolver::tokio(rc, opts)
+        }
+    };
+
+    // Ignore the error if another thread already initialised it.
+    let _ = DNS_RESOLVER.set(resolver);
+}
+
+/// Resolve a hostname to a `SocketAddr`, using the bound DNS resolver.
+///
+/// Falls back to `tokio::net::lookup_host` when the global resolver has not
+/// been initialised (should not happen in normal operation).
+pub async fn resolve_host(
+    host: &str,
+    port: u16,
+) -> std::io::Result<SocketAddr> {
+    if let Some(resolver) = DNS_RESOLVER.get() {
+        let lookup = resolver.lookup_ip(host).await.map_err(|e| {
+            std::io::Error::new(
+                std::io::ErrorKind::AddrNotAvailable,
+                format!("DNS lookup failed for '{}': {}", host, e),
+            )
+        })?;
+        let ip = lookup.iter().next().ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::AddrNotAvailable,
+                format!("DNS returned no addresses for '{}'", host),
+            )
+        })?;
+        Ok(SocketAddr::new(ip, port))
+    } else {
+        // Fallback: system resolver via tokio
+        use tokio::net::lookup_host;
+        let mut addrs = lookup_host((host, port)).await?;
+        addrs.next().ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::AddrNotAvailable,
+                format!("no addresses for '{}'", host),
+            )
+        })
+    }
+}
 
