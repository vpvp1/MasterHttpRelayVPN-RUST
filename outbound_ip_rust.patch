diff -ruN original/src/net_utils.rs MasterHttpRelayVPN-RUST/src/net_utils.rs
--- a/src/net_utils.rs	1970-01-01 00:00:00.000000000 +0000
+++ b/src/net_utils.rs	2026-05-15 10:02:26.490323620 +0000
@@ -0,0 +1,79 @@
+//! Outbound TCP connect helper with optional interface binding.
+//!
+//! All upstream connections in mhrv-rs go through `tcp_connect` instead of
+//! `TcpStream::connect` directly.  When `outbound_ip` is configured, the
+//! socket is bound to that IP before connecting — this forces the OS to route
+//! the connection through the interface that owns the address, regardless of
+//! the global routing table and regardless of which proxy mode is active
+//! (apps_script, direct, full).
+
+use std::net::{IpAddr, SocketAddr};
+use tokio::net::{TcpSocket, TcpStream};
+
+/// Open a TCP connection to `dest`.
+///
+/// If `outbound_ip` is `Some`, the socket is first bound to
+/// `<outbound_ip>:0` (port 0 = OS picks an ephemeral port) before the
+/// connect call.  This selects the network interface without changing any
+/// Windows routing tables.
+///
+/// If `outbound_ip` is `None` (the common case), this is a direct
+/// `TcpStream::connect` — zero overhead versus the old inline calls.
+pub async fn tcp_connect(
+    dest: impl tokio::net::ToSocketAddrs,
+    outbound_ip: Option<&str>,
+) -> std::io::Result<TcpStream> {
+    match outbound_ip {
+        None => TcpStream::connect(dest).await,
+        Some(ip_str) => {
+            let ip: IpAddr = ip_str.parse().map_err(|e| {
+                std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("outbound_ip '{}' is not a valid IP address: {}", ip_str, e),
+                )
+            })?;
+            // Use a v4 or v6 socket depending on the bind address type.
+            let socket = match ip {
+                IpAddr::V4(_) => TcpSocket::new_v4()?,
+                IpAddr::V6(_) => TcpSocket::new_v6()?,
+            };
+            socket.bind(SocketAddr::new(ip, 0))?;
+            // `TcpSocket::connect` requires a resolved `SocketAddr`, so we
+            // resolve `dest` the same way `TcpStream::connect` would.
+            use tokio::net::lookup_host;
+            let mut addrs = lookup_host(dest).await?;
+            let dest_addr = addrs.next().ok_or_else(|| {
+                std::io::Error::new(
+                    std::io::ErrorKind::AddrNotAvailable,
+                    "destination did not resolve to any address",
+                )
+            })?;
+            socket.connect(dest_addr).await
+        }
+    }
+}
+
+/// Variant that accepts a pre-resolved `SocketAddr` (avoids the extra
+/// `lookup_host` when the caller already has a resolved address).
+pub async fn tcp_connect_addr(
+    dest: SocketAddr,
+    outbound_ip: Option<&str>,
+) -> std::io::Result<TcpStream> {
+    match outbound_ip {
+        None => TcpStream::connect(dest).await,
+        Some(ip_str) => {
+            let ip: IpAddr = ip_str.parse().map_err(|e| {
+                std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("outbound_ip '{}' is not a valid IP address: {}", ip_str, e),
+                )
+            })?;
+            let socket = match ip {
+                IpAddr::V4(_) => TcpSocket::new_v4()?,
+                IpAddr::V6(_) => TcpSocket::new_v6()?,
+            };
+            socket.bind(SocketAddr::new(ip, 0))?;
+            socket.connect(dest).await
+        }
+    }
+}
